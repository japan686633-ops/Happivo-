{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Information about a potential client who submitted a contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the client." },
        "phone": { "type": "string", "description": "Phone number of the client." },
        "email": { "type": "string", "description": "Email address of the client." },
        "country": { "type": "string", "description": "Country of the client." },
        "date": { "type": "string", "description": "Submission date and time." }
      },
      "required": ["name", "phone", "email", "country", "date"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message sent by a client.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sender." },
        "contact": { "type": "string", "description": "Contact info (phone or email) of the sender." },
        "message": { "type": "string", "description": "The message content." },
        "date": { "type": "string", "description": "Submission date and time." }
      },
      "required": ["name", "contact", "message", "date"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of client contact submissions."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of direct messages from clients."
    }
  }
}
