rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: clients
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - phone: string (required)
    //   - email: string (required)
    //   - country: string (required)
    //   - date: string (required)
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - contact: string (required)
    //   - message: string (required)
    //   - date: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "japan686633@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'phone', 'email', 'country', 'date']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.country is string && data.country.size() > 0 && data.country.size() < 100 &&
             data.date is string;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'contact', 'message', 'date']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contact is string && data.contact.size() > 0 && data.contact.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.date is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /clients/{clientId} {
      allow read: if isAdmin();
      allow create: if isValidClient(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
